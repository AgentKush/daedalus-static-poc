---
permalink: "/search/index.html"
layout: layout.njk
rootPath: "../"
title: "Search | Project Daedalus"
description: "Full-text search across every mod listing and README on Project Daedalus."
---
<section class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl md:text-4xl font-extrabold text-icarus-500 mb-2">Search</h1>
  <p class="text-slate-600 dark:text-slate-400 mb-6">
    Searches mod names, descriptions, and the full text of every rendered README. Handles typos
    and partial matches.
  </p>

  <div id="search" class="daedalus-search"></div>
  <div id="nexus-search-section" class="mt-6" hidden>
    <h3 class="mb-3 text-sm uppercase tracking-wide text-icarus-500 font-semibold">
      Nexus Mods <span id="nexus-search-count" class="text-slate-500 normal-case font-normal"></span>
    </h3>
    <ul id="nexus-search-results" class="space-y-2"></ul>
  </div>
  <p class="mt-6 text-xs text-slate-500 dark:text-slate-400">Powered by <a href="https://pagefind.app" class="text-icarus-500 hover:underline">Pagefind</a> — index built at deploy time.</p>
</section>

<link href="{{ rootPath }}pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="{{ rootPath }}pagefind/pagefind-ui.js"></script>
<script>
  window.addEventListener("DOMContentLoaded", () => {
    new PagefindUI({
      element: "#search",
      showImages: false,
      showSubResults: true,
      autofocus: true,
      pageSize: 12,
      resetStyles: false,
      translations: { placeholder: "Search mods (e.g. 'speed crafting' or 'no decay')…" }
    });

    // Nexus-mods client-side search. Pagefind doesn't index Nexus mods because
    // they don't have per-mod pages on this site (they link out to nexusmods.com),
    // so we filter the bundled nexus_mods.json on every keystroke alongside Pagefind.
    let nexusMods = null;
    const section = document.getElementById("nexus-search-section");
    const list = document.getElementById("nexus-search-results");
    const count = document.getElementById("nexus-search-count");

    function renderNexus(query) {
      const q = (query || "").trim().toLowerCase();
      if (!q || !nexusMods) { section.hidden = true; return; }
      const matches = nexusMods.filter(m =>
        (m.name || "").toLowerCase().includes(q) ||
        (m.author || "").toLowerCase().includes(q) ||
        (m.description || "").toLowerCase().includes(q)
      ).slice(0, 12);
      if (!matches.length) { section.hidden = true; return; }
      section.hidden = false;
      count.textContent = `${matches.length} match${matches.length === 1 ? "" : "es"}`;
      const esc = (str) => (str || "").replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
      const mark = (text, q) => {
        const i = text.toLowerCase().indexOf(q);
        if (i < 0) return esc(text);
        return esc(text.slice(0, i)) + `<mark style="background:rgba(241,173,28,.25);color:inherit;padding:0 2px;border-radius:2px;">${esc(text.slice(i, i+q.length))}</mark>` + esc(text.slice(i+q.length));
      };
      list.innerHTML = matches.map(m => {
        const url = m.mod_page_url || `https://www.nexusmods.com/icarus/mods/${m.nexus_id}`;
        const week = m.compatibility ? `<span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-icarus-500/20 text-icarus-500">${esc(m.compatibility.toLowerCase())}</span>` : "";
        return `<li class="p-4 border rounded-lg border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800/50 hover:border-icarus-500 transition-colors">
          <a href="${esc(url)}" target="_blank" rel="noopener" class="no-underline">
            <div class="flex items-start justify-between gap-3 mb-1">
              <div class="font-bold text-icarus-500 text-base">${mark(m.name || "(unnamed)", q)} <span class="ml-2 text-[10px] uppercase tracking-wide bg-icarus-500/20 text-icarus-500 px-1.5 py-0.5 rounded">Nexus ↗</span></div>
              ${week}
            </div>
            <div class="text-xs text-slate-500 dark:text-slate-400 mb-1">by ${mark(m.author || "unknown", q)}</div>
            ${m.description ? `<div class="text-sm text-slate-700 dark:text-slate-300 opacity-85">${mark((m.description || "").slice(0, 220), q)}${(m.description||"").length>220?"…":""}</div>` : ""}
          </a>
        </li>`;
      }).join("");
    }

    fetch("../data/nexus_mods.json").then(r => r.ok ? r.json() : []).then(d => {
      nexusMods = d;
      const input = document.querySelector(".pagefind-ui__search-input");
      if (input) {
        renderNexus(input.value);
        input.addEventListener("input", () => renderNexus(input.value));
      }
    }).catch(() => {});
  });
</script>

<style>
  /* Theme Pagefind UI via its CSS custom properties — light mode default */
  .daedalus-search {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: #f1ad1c;          /* icarus-500 */
    --pagefind-ui-text: #1e293b;             /* slate-800 */
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #cbd5e1;           /* slate-300 */
    --pagefind-ui-tag: #f1f5f9;              /* slate-100 */
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-image-border-radius: 0.25rem;
    --pagefind-ui-font: Inter, ui-sans-serif, system-ui, sans-serif;
  }
  /* Dark mode overrides — site flips <html class="dark"> on the toggle */
  .dark .daedalus-search {
    --pagefind-ui-text: #e2e8f0;             /* slate-200 */
    --pagefind-ui-background: #0f172a;       /* slate-900 */
    --pagefind-ui-border: #334155;           /* slate-700 */
    --pagefind-ui-tag: #1e293b;              /* slate-800 */
  }

  /* Targeted overrides for elements that don't have CSS variables */
  .daedalus-search .pagefind-ui__search-input {
    color: var(--pagefind-ui-text);
    background: var(--pagefind-ui-background);
    box-shadow: 0 1px 2px rgba(0,0,0,.05);
  }
  .daedalus-search .pagefind-ui__search-input::placeholder {
    color: #94a3b8;                           /* slate-400 — readable on light AND dark */
    opacity: 1;
  }
  .daedalus-search .pagefind-ui__search-clear {
    color: var(--pagefind-ui-text);
    opacity: 0.7;
  }
  .daedalus-search .pagefind-ui__search-clear:hover { opacity: 1; }

  /* Result count message */
  .daedalus-search .pagefind-ui__message {
    color: var(--pagefind-ui-text);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 0.25rem;
    margin-top: 1rem;
  }

  /* Result cards — proper border + spacing, not white separators */
  .daedalus-search .pagefind-ui__results-area { margin-top: 0.75rem; }
  .daedalus-search .pagefind-ui__result,
  .daedalus-search .pagefind-ui__results-area > .pagefind-ui__result,
  .daedalus-search ol > li.pagefind-ui__result {
    background: var(--pagefind-ui-background) !important;
    border: 1px solid var(--pagefind-ui-border) !important;
    border-radius: 0.5rem !important;
    padding: 1.25rem 1.5rem !important;
    margin-bottom: 0.75rem !important;
    transition: border-color 120ms ease, transform 120ms ease;
    list-style: none !important;
  }
  .daedalus-search .pagefind-ui__result:hover {
    border-color: var(--pagefind-ui-primary) !important;
    transform: translateY(-1px);
  }
  /* Pagefind sometimes renders an inner wrapper — make sure its margins/padding don't fight ours */
  .daedalus-search .pagefind-ui__result-inner,
  .daedalus-search .pagefind-ui__result > * {
    margin-left: 0 !important;
    margin-right: 0 !important;
  }
  /* Mod name (the main link) — gold, prominent */
  .daedalus-search .pagefind-ui__result-title {
    margin: 0 0 0.4rem 0 !important;
    padding: 0 !important;
  }
  .daedalus-search .pagefind-ui__result-link {
    color: var(--pagefind-ui-primary) !important;
    font-weight: 700 !important;
    font-size: 1.1rem !important;
    text-decoration: none !important;
    line-height: 1.3 !important;
  }
  .daedalus-search .pagefind-ui__result-link:hover { text-decoration: underline !important; }

  /* Description / excerpt — readable contrast and proper inset */
  .daedalus-search .pagefind-ui__result-excerpt {
    color: var(--pagefind-ui-text) !important;
    opacity: 0.85;
    font-size: 0.9rem !important;
    line-height: 1.55 !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .daedalus-search .pagefind-ui__result-excerpt mark {
    background: rgba(241, 173, 28, 0.25);
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }
  /* Sub-results (matched headings within a page) */
  .daedalus-search .pagefind-ui__result-nested {
    border-left: 2px solid var(--pagefind-ui-border);
    padding-left: 0.75rem;
    margin-left: 0.25rem;
    margin-top: 0.5rem;
  }

  /* "Load more" button */
  .daedalus-search .pagefind-ui__button {
    background: var(--pagefind-ui-primary);
    color: #0f172a;
    border: none;
    font-weight: 600;
    border-radius: 0.5rem;
    padding: 0.5rem 1.25rem;
  }
  .daedalus-search .pagefind-ui__button:hover { filter: brightness(1.1); }

  /* Drawer/filters (we don't use them but suppress white background if shown) */
  .daedalus-search .pagefind-ui__drawer { background: var(--pagefind-ui-background); }
</style>
