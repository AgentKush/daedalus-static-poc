---
pagination:
  data: tags
  size: 1
  alias: tag
permalink: "/tag/{{ tag.slug }}/index.html"
layout: layout.njk
rootPath: "../../"
eleventyComputed:
  title: "{{ tag.tag | title }} mods | Project Daedalus"
  description: "{{ tag.count }} Icarus mod(s) tagged '{{ tag.tag }}'."
---
<section class="max-w-5xl mx-auto px-4 py-6 md:py-10">
  <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
    <div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-icarus-500"><span class="text-slate-400 dark:text-slate-500">#</span>{{ tag.tag }}</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{{ tag.count }} mod{% if tag.count != 1 %}s{% endif %} tagged this</p>
    </div>
    <a href="{{ rootPath }}" class="text-sm text-icarus-500 hover:underline">← all mods</a>
  </div>

  <div class="grid gap-3 md:grid-cols-2">
    {% for m in tag.mods %}
      {% set href = (m.mod_page_url if m.source == "nexus" else (rootPath + "mods/" + m.author_slug + "/" + m.slug + "/")) %}
      {% set ext = m.source == "nexus" %}
      <a href="{{ href }}" {% if ext %}target="_blank" rel="noopener"{% endif %} class="block p-4 border rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800 no-underline">
        <div class="flex items-start justify-between gap-3 mb-1">
          <div class="font-semibold text-slate-800 dark:text-slate-200">{{ m.name }}{% if m.source == "nexus" %} <span class="ml-1 text-[10px] uppercase tracking-wide bg-icarus-500/20 text-icarus-500 px-1.5 py-0.5 rounded font-bold">Nexus ↗</span>{% endif %}</div>
          <div class="flex gap-1 flex-shrink-0">
            {% for t in m.file_types %}
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase
                {% if t == 'exmodz' %}bg-icarus-500/20 text-icarus-500
                {% elif t == 'pak' %}bg-emerald-500/20 text-emerald-600
                {% else %}bg-slate-500/20 text-slate-600{% endif %}">{{ t }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2 text-xs text-slate-500 dark:text-slate-400">
          <span>by {% if m.source == "nexus" %}<span>{{ m.author }}</span>{% else %}<a href="{{ rootPath }}authors/{{ m.author_slug }}/" class="hover:text-icarus-500" onclick="event.stopPropagation()">{{ m.author }}</a>{% endif %}</span>
          {% if m.version %}<span>· v{{ m.version }}</span>{% endif %}
          {% if m.compatibility %}<span class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-icarus-500/20 text-icarus-500 dark:text-icarus-400 font-medium">{{ m.compatibility | lower }}</span>{% endif %}
        </div>
        {% if m.description %}<p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">{{ m.description | truncate(160) }}</p>{% endif %}
      </a>
    {% endfor %}
  </div>
</section>
