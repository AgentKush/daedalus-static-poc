---
pagination:
  data: detailMods
  size: 1
  alias: mod
permalink: "/mods/{{ mod.author_slug }}/{{ mod.slug }}/index.html"
layout: layout.njk
rootPath: "../../../"
eleventyComputed:
  title: "{{ mod.name }} by {{ mod.author }} | ProjectDaedalus"
  description: "{{ mod.description | striptags | truncate(160) }}"
  og_image: "{{ mod.image_url }}"
---
<section class="max-w-5xl mx-auto px-4 py-6 md:py-10" data-pagefind-body data-pagefind-meta="title:{{ mod.name | safe }}" data-pagefind-meta-author="{{ mod.author | safe }}">
  <!-- Tag chips for this mod -->
  {% set myTags = modTags[mod.id] | default([]) %}
  {% if myTags | length %}
    <div class="flex flex-wrap items-center gap-1.5 mt-3 mb-1">
      <span class="text-xs uppercase tracking-wide text-slate-500 mr-1">Tags</span>
      {% for t in myTags %}
        <a href="{{ rootPath }}tag/{{ t }}/" class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-200/70 dark:bg-slate-700/50 text-slate-700 dark:text-slate-300 hover:bg-icarus-500/20 hover:text-icarus-500 no-underline">#{{ t }}</a>
      {% endfor %}
    </div>
  {% endif %}
  <!-- Header: name + file type badges + download buttons -->
  <div class="flex items-center justify-between flex-auto flex-wrap gap-3">
    <div class="flex items-center gap-3 flex-1 min-w-0">
      <div class="text-2xl font-extrabold tracking-tight text-icarus-500 md:text-4xl">{{ mod.name }}</div>
      <div class="flex gap-1.5 flex-shrink-0">
        {% for type in mod.file_types %}
          {% if type == "exmodz" %}
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-icarus-500/20 text-icarus-500 dark:bg-icarus-500/10 dark:text-icarus-400">{{ type }}</span>
          {% elif type == "pak" %}
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-emerald-500/20 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400">{{ type }}</span>
          {% else %}
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-slate-500/20 text-slate-600 dark:bg-slate-500/10 dark:text-slate-400">{{ type }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="flex gap-2 flex-shrink-0 flex-wrap">
      {% for d in mod.downloads %}
        <a href="{{ d.url }}" download="{{ d.filename }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white rounded-md shadow-sm bg-icarus-500 hover:bg-icarus-600">DOWNLOAD {{ d.type | upper }}</a>
      {% endfor %}
    </div>
  </div>

  <!-- Author + version line -->
  <div class="flex items-center justify-between flex-auto mt-1 flex-wrap gap-2">
    <div class="text-lg text-icarus-400 lg:text-xl">By <a href="{{ rootPath }}authors/{{ mod.author_slug }}/" class="text-icarus-400 hover:text-icarus-500 underline-offset-2 hover:underline">{{ mod.author }}</a></div>
    <div class="text-slate-500">{{ mod.version_string }}</div>
  </div>

  <!-- EXMODZ note + dates -->
  <div class="flex items-start justify-between flex-auto mt-2 flex-wrap gap-2">
    <div class="text-sm text-slate-500 dark:text-slate-400">
      {% if mod.has_exmodz %}
        This Mod includes an EXMOD formatted file, which doesn't need updates each week.<br>
        We recommend you use a Mod Manager to install this mod.
      {% endif %}
    </div>
    {% if mod.updated_string %}
      <div class="text-sm text-right text-slate-500 flex-shrink-0">
        <div>{{ mod.updated_string }}</div>
      </div>
    {% endif %}
  </div>

  <!-- Compatibility badge -->
  {% if mod.compatibility %}
    <div class="mt-3">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-icarus-500/20 text-icarus-500 dark:bg-icarus-500/10 dark:text-icarus-400">{{ mod.compatibility | lower }}</span>
    </div>
  {% endif %}

  {% set primaryModUrl = "" %}
  {%- if mod.downloads and mod.downloads | length -%}{% set primaryModUrl = mod.downloads[0].url %}{%- elif mod.readme_url -%}{% set primaryModUrl = mod.readme_url %}{%- elif mod.image_url -%}{% set primaryModUrl = mod.image_url %}{%- endif %}
  <details class="mt-3 group" data-mod-id="{{ mod.id }}" data-mod-primary-url="{{ primaryModUrl }}" data-mod-has-files="{{ '1' if mod.downloads and mod.downloads | length else '0' }}">
    <summary class="flex items-center gap-1 text-xs cursor-pointer text-icarus-500 hover:text-icarus-400 list-none">
      <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      Analytics for Mod Authors
    </summary>
    <div class="mt-3 mb-6 space-y-4">
      <h3 class="text-lg font-semibold text-icarus-500">Analytics</h3>

      <!-- Row 1: 4-card dashboard -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
          <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">File Types</div>
          <div class="flex gap-1.5 mt-1">
            {% for type in mod.file_types %}
              {% if type == "exmodz" %}<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-icarus-500/20 text-icarus-500">{{ type }}</span>
              {% elif type == "pak" %}<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-emerald-500/20 text-emerald-600 dark:text-emerald-400">{{ type }}</span>
              {% else %}<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-slate-500/20 text-slate-600 dark:text-slate-400">{{ type }}</span>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
          <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">Mod Age</div>
          <div class="mt-1 text-sm text-slate-700 dark:text-slate-300" data-analytics="mod-age">
            <span class="text-slate-400">loading…</span>
          </div>
        </div>

        <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
          <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">Freshness</div>
          <div class="mt-1 text-sm text-slate-700 dark:text-slate-300" data-analytics="freshness">
            <span class="text-slate-400">loading…</span>
          </div>
        </div>

        <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
          <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">Your Activity</div>
          <div class="mt-1 text-sm text-slate-700 dark:text-slate-300">
            <span id="analytics-view-count">0</span> views &middot;
            <span id="analytics-download-count">0</span> downloads
          </div>
          <div class="text-xs text-slate-500 dark:text-slate-400">From this browser</div>
        </div>
      </div>

      <!-- Row 2: Compatibility -->
      {% if mod.compatibility %}
      <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
        <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">Compatibility</div>
        <div class="flex items-center gap-3 mt-2 flex-wrap">
          <span class="inline-flex items-center px-3 py-1 text-sm font-semibold rounded-full bg-icarus-500/20 text-icarus-500">{{ mod.compatibility }}</span>
          {% if mod.has_exmodz %}<span class="text-xs text-emerald-500">EXMOD format — may work across updates</span>{% endif %}
        </div>
      </div>
      {% endif %}

      <!-- Row 3: Author stats -->
      {% if mod.author_stats.total_mods > 0 %}
      <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
        <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">Author: {{ mod.author }}</div>
        <div class="grid grid-cols-1 gap-4 mt-3 sm:grid-cols-3">
          <div>
            <div class="text-xl font-bold text-icarus-500">{{ mod.author_stats.total_mods }}</div>
            <div class="text-xs text-slate-500 dark:text-slate-400">Total Mods</div>
          </div>
          <div>
            <div class="flex gap-3 mt-1 flex-wrap">
              {% for entry in mod.author_stats.file_type_counts %}
                <span class="text-xs text-slate-500 dark:text-slate-400">{{ entry[0] | upper }}: {{ entry[1] }}</span>
              {% endfor %}
            </div>
            <div class="text-xs text-slate-500 dark:text-slate-400 mt-1">File Types</div>
          </div>
          <div data-analytics="newest-by-author">
            <div class="text-xs text-slate-400 italic">loading most-recent…</div>
          </div>
        </div>
      </div>
      {% endif %}

      <!-- GitHub Stats (lazy-loaded when panel opens) -->
      <div id="github-stats-slot"></div>

      <!-- Row 4: Mod Status — populated by mod-analytics-live.js using the freshness data + downloads -->
      <div class="p-4 border rounded-lg border-slate-300/50 dark:border-slate-600/50 bg-slate-300/40 dark:bg-slate-900/40">
        <div class="text-xs font-medium tracking-wide uppercase text-icarus-500">Mod Status</div>
        <div data-analytics="mod-status" class="mt-2 text-sm text-slate-500">checking…</div>
      </div>
    </div>
  </details>

  <!-- Gold separator -->
  <div class="mt-4 gold-line"></div>

  <!-- Content: image (float-right at md+) + markdown -->
  <div class="mt-6 min-h-48">
    {% if mod.image_url %}
      <img class="hidden float-right w-48 h-48 mb-5 ml-5 rounded md:block object-cover" src="{{ mod.image_url }}" alt="{{ mod.name }}" onerror="this.style.display='none'">
    {% endif %}
    <div class="pt-2 pb-12 prose dark:prose-invert lg:prose-xl text-slate-700 dark:text-slate-300">{{ mod.readme_html | safe }}</div>
    {% if not mod.has_full_readme %}
      <p class="mt-2 text-xs italic text-slate-500">Full README will load dynamically once the site is wired to live Firestore.</p>
    {% endif %}
  </div>

  <!-- Gold separator -->
  <div class="gold-line"></div>

  <!-- Other mods by this author -->
  {% if mod.other_by_author.length %}
    <div class="mt-6">
      <h3 class="mb-3 text-base font-semibold tracking-wide text-icarus-500 lg:text-lg">Other mods by {{ mod.author }}</h3>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {% for other in mod.other_by_author %}
          <a href="{{ rootPath }}mods/{{ other.author_slug }}/{{ other.slug }}/" class="flex items-center justify-between p-3 text-left transition-colors border rounded-lg border-slate-200 dark:border-slate-700 hover:border-icarus-500/50 hover:bg-slate-50 dark:hover:bg-slate-800/70 no-underline">
            <div class="min-w-0">
              <div class="text-sm font-medium truncate text-slate-800 dark:text-slate-200">{{ other.name }}</div>
              <div class="text-xs text-slate-500 truncate">{{ other.description }}</div>
            </div>
            <div class="flex gap-1 ml-2 flex-shrink-0">
              {% for type in other.file_types %}
                {% if type == "exmodz" %}<span class="px-1.5 py-0.5 text-xs rounded font-medium bg-icarus-500/20 text-icarus-500">{{ type | upper }}</span>
                {% elif type == "pak" %}<span class="px-1.5 py-0.5 text-xs rounded font-medium bg-emerald-500/20 text-emerald-600">{{ type | upper }}</span>
                {% else %}<span class="px-1.5 py-0.5 text-xs rounded font-medium bg-slate-500/20 text-slate-500">{{ type | upper }}</span>
                {% endif %}
              {% endfor %}
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Prev / Back / Next navigation -->
  <div class="flex items-center justify-between mt-6 mb-4 gap-2">
    <div class="flex-1">
      {% if mod.prev %}
        <a href="{{ rootPath }}mods/{{ mod.prev.author_slug }}/{{ mod.prev.slug }}/" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-slate-600 dark:text-slate-400 hover:text-icarus-500 dark:hover:text-icarus-400 no-underline transition-colors">&larr; {{ mod.prev.name | truncate(25) }}</a>
      {% endif %}
    </div>
    <div class="flex-shrink-0">
      <a href="{{ rootPath }}" class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md shadow-sm border border-icarus-500 text-icarus-500 hover:bg-icarus-500 hover:text-white no-underline transition-colors">Back to List</a>
    </div>
    <div class="flex-1 text-right">
      {% if mod.next %}
        <a href="{{ rootPath }}mods/{{ mod.next.author_slug }}/{{ mod.next.slug }}/" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-slate-600 dark:text-slate-400 hover:text-icarus-500 dark:hover:text-icarus-400 no-underline transition-colors">{{ mod.next.name | truncate(25) }} &rarr;</a>
      {% endif %}
    </div>
  </div>

  <!-- Gold separator -->
  <div class="gold-line"></div>

  
  <!-- Showcase video (if modder declared it) -->
  {% if mod.video_url %}
    <div class="mt-10 aspect-video rounded-lg overflow-hidden border border-slate-300/50 dark:border-slate-700/50 bg-black">
      {% set ytId = "" %}
      {% if "youtu.be/" in mod.video_url %}{% set ytId = mod.video_url | split("youtu.be/") | last | split("?") | first %}
      {% elif "youtube.com/watch" in mod.video_url %}{% set ytId = mod.video_url | split("v=") | last | split("&") | first %}
      {% elif "youtube.com/embed/" in mod.video_url %}{% set ytId = mod.video_url | split("embed/") | last | split("?") | first %}
      {% endif %}
      {% if ytId %}
        <iframe class="w-full h-full" src="https://www.youtube-nocookie.com/embed/{{ ytId }}" title="{{ mod.name }} showcase" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      {% else %}
        <a href="{{ mod.video_url }}" target="_blank" rel="noopener" class="block p-4 text-center text-icarus-500 underline">📺 Watch showcase video on the modder's site →</a>
      {% endif %}
    </div>
  {% endif %}

  <!-- Support / donate (if modder declared it) -->
  {% if mod.donate_url %}
    <div class="mt-8">
      <a href="{{ mod.donate_url }}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-md border-2 border-emerald-500 text-emerald-500 hover:bg-emerald-500 hover:text-white no-underline transition-colors">
        ❤️&nbsp;Support {{ mod.author }}
      </a>
      <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">If this mod's been useful, the author appreciates the support.</p>
    </div>
  {% endif %}

  <!-- You might also like — based on shared tags + same author + similar files -->
  {% if mod.similar and (mod.similar | length) %}
    <div class="mt-12">
      <h3 class="text-lg font-semibold text-icarus-500 mb-3">You might also like</h3>
      <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
        {% for s in mod.similar %}
          <a href="{{ rootPath }}mods/{{ s.author_slug }}/{{ s.slug }}/" class="block p-3 border rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 hover:border-icarus-500 no-underline transition-colors">
            <div class="font-semibold text-slate-800 dark:text-slate-200 mb-1">{{ s.name }}</div>
            <div class="flex items-center gap-2 mb-1 text-xs text-slate-500 dark:text-slate-400">
              <span>by {{ s.author }}</span>
              {% if s.compatibility %}<span class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-icarus-500/20 text-icarus-500 dark:text-icarus-400 font-medium">{{ s.compatibility | lower }}</span>{% endif %}
            </div>
            {% if s.description %}<p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2">{{ s.description | truncate(140) }}</p>{% endif %}
          </a>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Share row — separated from the cards above by a thin divider for clarity -->
  <div class="mt-12 pt-6 border-t border-slate-200 dark:border-slate-700">
    <div id="share-widget"></div>
  </div>
  <script src="{{ rootPath }}assets/share.js" defer></script>

  <!-- Discussion: ratings + comments via GitHub login -->
  <div class="mt-6">
    <h2 class="text-xl md:text-2xl font-bold text-icarus-500 mb-4">Discussion</h2>

    <div id="rating-widget" data-mod-id="{{ mod.id }}" class="flex items-center gap-3 flex-wrap p-4 mb-4 border rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50">
      <span class="text-xs uppercase tracking-wide text-icarus-500 font-medium">Rate this mod</span>
      <div id="rating-stars" class="flex items-center"></div>
      <div id="rating-summary" class="text-sm text-slate-500"></div>
    </div>

    <div class="p-4 border rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50">
      <p class="text-xs text-slate-500 mb-3">Sign in with GitHub to leave a comment. Threads are stored in the daedalus-static-poc repo's GitHub Discussions.</p>
      <div id="giscus-container">
        <script src="https://giscus.app/client.js"
                data-repo="AgentKush/daedalus-static-poc"
                data-repo-id="R_kgDOSTA-uQ"
                data-category="General"
                data-category-id="DIC_kwDOSTA-uc4C8QAM"
                data-mapping="specific"
                data-term="mod-{{ mod.id }}"
                data-strict="0"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="bottom"
                data-theme="dark_dimmed"
                data-lang="en"
                crossorigin="anonymous"
                defer></script>
      </div>
      <p class="mt-3 text-xs text-slate-500 italic">
        Comments and reactions are stored in GitHub Discussions, so they may
        take a moment to register on first interaction.
      </p>
    </div>
  </div>
</section>

<script>
  (function () {
    const KEY = "daedalus.activity";
    const det = document.querySelector("details[data-mod-id]");
    if (!det) return;
    const modId = det.dataset.modId;

    function read() {
      try { return JSON.parse(localStorage.getItem(KEY) || "{}"); } catch (e) { return {}; }
    }
    function write(s) { localStorage.setItem(KEY, JSON.stringify(s)); }

    const store = read();
    const entry = store[modId] = store[modId] || { views: 0, downloads: 0 };
    entry.views += 1;
    write(store);

    document.getElementById("analytics-view-count").textContent = entry.views;
    document.getElementById("analytics-download-count").textContent = entry.downloads;

    // Increment download count when any download button fires
    document.querySelectorAll('a[download]').forEach(a => {
      a.addEventListener("click", () => {
        const s = read();
        const e = s[modId] = s[modId] || { views: 0, downloads: 0 };
        e.downloads += 1;
        write(s);
        document.getElementById("analytics-download-count").textContent = e.downloads;
      });
    });
  })();
</script>
<script type="module" src="{{ rootPath }}assets/ratings.js"></script>
<script src="{{ rootPath }}assets/github-stats.js" defer></script>
<script type="module" src="{{ rootPath }}assets/mod-analytics-live.js"></script>
<script type="module" src="{{ rootPath }}assets/mod-readme-live.js"></script>

<script type="module">
  import { record } from "{{ rootPath }}assets/recently-viewed.js";
  record({
    name: {{ mod.name | dump | safe }},
    author: {{ mod.author | dump | safe }},
    author_slug: {{ mod.author_slug | dump | safe }},
    slug: {{ mod.slug | dump | safe }}
  });
</script>
