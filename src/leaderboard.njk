---
permalink: "/leaderboard/index.html"
layout: layout.njk
rootPath: "../"
title: "Modder leaderboard | Project Daedalus"
description: "Top Icarus mod authors by total mod count."
---
<section class="max-w-3xl mx-auto px-4 py-8">
  <h1 class="text-3xl md:text-4xl font-extrabold text-icarus-500 mb-2">Modder leaderboard</h1>
  <p class="text-slate-600 dark:text-slate-400 mb-6">Top contributors by mod count. Click an author to see all their mods.</p>

  <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-700">
    <table class="w-full text-sm">
      <thead class="bg-slate-100 dark:bg-slate-800/70 text-slate-600 dark:text-slate-300">
        <tr>
          <th class="text-left p-3 w-16">#</th>
          <th class="text-left p-3">Author</th>
          <th class="text-right p-3">Mods</th>
          <th class="text-left p-3 hidden md:table-cell">File types</th>
          <th class="text-left p-3 hidden md:table-cell">Latest</th>
        </tr>
      </thead>
      <tbody>
        {% for a in authorsByCount %}
          {% set rank = loop.index %}
          <tr class="border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 hover:bg-slate-50 dark:hover:bg-slate-800/70">
            <td class="p-3 font-mono text-slate-500">
              {% if rank == 1 %}🥇{% elif rank == 2 %}🥈{% elif rank == 3 %}🥉{% else %}{{ rank }}{% endif %}
            </td>
            <td class="p-3">
              <a href="{{ rootPath }}authors/{{ a.slug }}/" class="font-medium text-slate-800 dark:text-slate-200 hover:text-icarus-500 no-underline">{{ a.author }}</a>
            </td>
            <td class="p-3 text-right font-bold text-icarus-500">{{ a.mod_count }}</td>
            <td class="p-3 hidden md:table-cell">
              <div class="flex gap-1 flex-wrap">
                {% for type, count in a.file_type_counts %}
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase
                    {% if type == 'exmodz' %}bg-icarus-500/20 text-icarus-500
                    {% elif type == 'pak' %}bg-emerald-500/20 text-emerald-600
                    {% else %}bg-slate-500/20 text-slate-600{% endif %}">{{ type }} {{ count }}</span>
                {% endfor %}
              </div>
            </td>
            <td class="p-3 hidden md:table-cell text-slate-500 dark:text-slate-400 text-xs">
              {% if a.newest_mod and a.newest_mod.compatibility %}{{ a.newest_mod.compatibility | lower }}{% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
