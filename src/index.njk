    <p class="max-w-2xl mx-auto text-base text-slate-600 dark:text-slate-400 md:text-lg">
      Browse and download community-made mods for the Icarus survival game.
    </p>
    <div class="mx-auto mt-4 gold-line w-48"></div>
  </div>

  <div class="flex flex-col gap-3 p-4 mb-6 border rounded-xl border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 md:flex-row md:items-center md:justify-between">
