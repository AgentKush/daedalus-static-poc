  <div class="hidden mb-4 text-sm text-center md:block text-slate-500 dark:text-slate-400">
    Don't see a feature you're looking for? Go upvote or add it on
    <a href="./requests.html" class="font-medium no-underline text-icarus-500 hover:text-icarus-400">the Mod Requests board</a>
  </div>
  <p class="mb-4 text-xs text-center text-icarus-500">Click on any row to view additional mod details</p>

  <div class="overflow-hidden border rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 mt-2">
    <table class="w-full border-collapse table-auto">
      <thead>
        <tr class="bg-slate-100 dark:bg-slate-800">
          <th class="p-3 text-left text-sm font-semibold text-icarus-500 sm:w-1/5">Name</th>
          <th class="p-3 text-left text-sm font-semibold text-icarus-500 w-auto sm:w-28">Download</th>
          <th class="hidden p-3 text-left text-sm font-semibold text-icarus-500 sm:table-cell sm:w-1/6">Author</th>
          <th class="hidden p-3 text-right text-sm font-semibold text-icarus-500 md:table-cell w-20">Version</th>
          <th class="hidden p-3 text-center text-sm font-semibold text-icarus-500 xl:table-cell w-20">Week</th>
          <th class="hidden p-3 text-left text-sm font-semibold text-icarus-500 xl:table-cell">Description</th>
        </tr>
      </thead>
      <tbody id="rows"></tbody>
    </table>
  </div>

  <div class="mt-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-2">
    <p id="page-info" class="text-sm text-slate-500 text-center sm:text-left"></p>
    <nav id="pagination" class="flex flex-wrap items-center justify-center sm:justify-end gap-y-1"></nav>
  </div>

  <div class="mt-6 text-sm text-center text-slate-500 dark:text-slate-400">
    Want to see a new mod?
    <a href="./requests.html" class="font-medium no-underline text-icarus-500 hover:text-icarus-400">Submit or upvote mod requests</a>
  </div>
</div>

